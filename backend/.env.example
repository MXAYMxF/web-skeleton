# Backend environment example.
# Copy to `.env` and fill in as needed. Every value here has a safe default in
# app/core/config.py, so the app boots with an empty .env.

# --- AI / LLM layer ---------------------------------------------------------
# Provider selection. The registry falls back to the network-free "mock"
# provider whenever the selected provider has no key configured, so a fresh
# clone (and `pytest`) runs offline with zero AI config.
#   mock       -> deterministic, no SDK, no network (default)
#   anthropic  -> Claude via the `anthropic` SDK  (requires ANTHROPIC_API_KEY)
#   openai     -> GPT via the `openai` SDK        (requires OPENAI_API_KEY)
AI_PROVIDER=mock

# API keys are SERVER-SIDE ONLY. They are read here into `settings`, used only by
# the backend to call the provider, and are NEVER returned by any endpoint or
# sent to the browser. Do NOT create a NEXT_PUBLIC_* copy of these — that would
# ship the secret to every visitor. The frontend talks to POST /api/v1/ai/chat,
# which talks to the provider on the server's behalf.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional per-request default model. Leave blank to let each provider pick its
# own default (Anthropic -> claude-sonnet-4-6; OpenAI -> gpt-4o-mini [verify]).
# Valid Claude IDs (do NOT add date suffixes):
#   claude-opus-4-8 | claude-sonnet-4-6 | claude-haiku-4-5 | claude-fable-5
AI_DEFAULT_MODEL=

# Server-side hard cap on output tokens per request (clamps client requests).
AI_MAX_TOKENS=1024

# Provider request timeout, seconds.
AI_REQUEST_TIMEOUT_SECONDS=60
